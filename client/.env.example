# Production API base URL — only needed when deploying frontend separately from backend
# Leave blank in local dev (Vite dev server proxies /api to localhost:3001 automatically)
VITE_API_BASE_URL=https://your-api.railway.app/api/v1

# Cloudinary — for item photo uploads
# 1. Create a free account at cloudinary.com
# 2. Settings → Upload → Upload presets → Add unsigned preset
VITE_CLOUDINARY_CLOUD_NAME=dxxu1lk7l
VITE_CLOUDINARY_UPLOAD_PRESET=stageflow_preset
