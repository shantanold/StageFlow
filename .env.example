# ─── Server (server/.env) ─────────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev: postgresql://YOUR_USER@localhost:5432/stageflow
# Production: get from Supabase / Neon dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stageflow"

# Random secret for signing JWTs — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-secret"

# Server port (Railway/Render set this automatically)
PORT=3001

# Allowed CORS origin — set to your Vercel/Netlify URL in production
CORS_ORIGIN="http://localhost:5173"

# ─── Client (client/.env) ─────────────────────────────────────────────────────

# Only needed in production. Leave blank for local dev (Vite proxy handles it).
# VITE_API_BASE_URL=https://your-api.railway.app/api/v1
